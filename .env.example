# ─────────────────────────────────────────────────────────────────────────────
# SEO Command — environment variables
# Copy this file to .env and fill in the values for your environment.
#
# Quick start (local dev without Docker):
#   cp .env.example .env
#   # Fill in DATABASE_URL, SESSION_SECRET, ADMIN_PASSWORD, APP_URL
#   pnpm --filter @workspace/db run push
#   PORT=5000 pnpm --filter @workspace/api-server run dev
#   PORT=5173 BASE_PATH=/ pnpm --filter @workspace/marketing-hub run dev
#
# Or run the one-command setup script:
#   bash scripts/setup.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# Local development (direct PostgreSQL connection — no Docker required)
# Create a local database first, e.g.:
#   createdb marketing_hub
# then set the URL below:
DATABASE_URL=postgresql://postgres:password@localhost:5432/marketing_hub

# ── Docker / hosted PostgreSQL (choose one of the two options below) ──────────

# Option A — Bundled PostgreSQL via Docker Compose (default, easiest for Docker)
# docker compose handles the postgres container for you.
# Only set DB_PASSWORD; DATABASE_URL is constructed automatically inside Docker.
DB_PASSWORD=change_me_to_something_strong

# Option B — External / Supabase PostgreSQL
# Comment out DB_PASSWORD above and set SUPABASE_DATABASE_URL instead.
# The app will connect with SSL and skip the built-in postgres container.
# Example (Supabase transaction pooler on port 6543):
#   SUPABASE_DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# Example (any external postgres):
#   SUPABASE_DATABASE_URL=postgresql://user:password@db.example.com:5432/seocommand
SUPABASE_DATABASE_URL=

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens.  Keep this secret.
# Generate: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string_minimum_32_chars

# Password for the auto-created "admin" account (only applied on first boot).
# After first login you can change it from Settings → Security.
ADMIN_PASSWORD=change_me_admin_password

# ── Application URL ───────────────────────────────────────────────────────────
# Full public URL where the app will be reachable (used in email links,
# OAuth callbacks, UTM tracking, etc.).  Include the scheme, no trailing slash.
# Local dev: use the API server URL (http://localhost:5000).
# The frontend at http://localhost:5173 calls this URL for OAuth callbacks, emails, etc.
# Production example: https://seo.yourdomain.com
APP_URL=http://localhost:5000

# ── Service ports (local development only) ────────────────────────────────────
# API server port — used when starting directly (not via Docker)
PORT=5000
# Base URL path the frontend is served from (use "/" for local dev)
BASE_PATH=/

# ── AI Provider ───────────────────────────────────────────────────────────────
# Primary AI key — accepts an OpenAI-compatible key (OpenAI, Anthropic via proxy, etc.)
# You can also configure providers from Settings → AI Provider in the app.
AI_API_KEY=

# Replit-managed AI integrations proxy (set automatically on Replit; leave blank elsewhere)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ── Google Integrations (optional) ───────────────────────────────────────────
# Required for Google Search Console and GA4 integrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an authorised redirect URI in your Google Cloud project.
# Example: https://seo.yourdomain.com/api/integrations/google/callback
GOOGLE_REDIRECT_URI=
# Required for the PageSpeed / Core Web Vitals scanner.
GOOGLE_PAGESPEED_API_KEY=

# ── Social Media OAuth (optional) ────────────────────────────────────────────
# Required for connecting Twitter/X, LinkedIn, Facebook, Instagram accounts.
# Callback URLs to register in each developer portal:
#   Twitter/X:  https://seo.yourdomain.com/api/integrations/social/twitter/callback
#   LinkedIn:   https://seo.yourdomain.com/api/integrations/social/linkedin/callback
#   Facebook:   https://seo.yourdomain.com/api/integrations/social/facebook/callback
#   Instagram:  https://seo.yourdomain.com/api/integrations/social/instagram/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Email / SMTP (optional) ───────────────────────────────────────────────────
# 32-byte hex key used to encrypt SMTP credentials stored in the database.
# Falls back to SESSION_SECRET if not set.
# Generate: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=

# SendGrid inbound webhook signing key (only needed for inbound email parsing)
SENDGRID_WEBHOOK_KEY=
# Mailgun webhook signing key (only needed for Mailgun inbound webhooks)
MAILGUN_WEBHOOK_SIGNING_KEY=
# Resend webhook signing secret (only needed for Resend delivery webhooks)
RESEND_WEBHOOK_SECRET=

# ── Image / video generation (optional) ───────────────────────────────────────
# fal.ai API key for AI image and video generation features
FAL_AI_API_KEY=
# Some fal.ai client libraries read FAL_KEY instead of FAL_AI_API_KEY
FAL_KEY=

# ── Google PageSpeed (optional — alias) ───────────────────────────────────────
# Alternative name recognised by some modules; set the same value as
# GOOGLE_PAGESPEED_API_KEY if your deployment reads this variable instead.
PAGESPEED_API_KEY=

# ── Logging (optional) ────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ── Host port ─────────────────────────────────────────────────────────────────
# The local port Docker binds nginx to.  Change to 8080 if port 80 is taken.
HOST_PORT=80
